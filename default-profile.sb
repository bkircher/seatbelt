;; default-profile.sb - Default Seatbelt profile for macOS.
;;
;; Policy:
;;   - Start from deny-default.
;;
;;   Reads:
;;     - Reads outside the users directory remain allowed, so system tools keep
;;       working.
;;     - Reads inside the users directory are blocked unless they match one of the
;;       exceptions.
;;     - Metadata reads of the users directory and the home directory remain
;;       allowed so runtimes can resolve real paths without granting directory
;;       listing access.
;;
;;   Writes:
;;     - Writes are denied by default and only allowed to explicitly listed paths.
;;     - Writes are allowed to the project directory and other explicitly allowed
;;       paths.
;;     - Writes to sensitive project files remain denied even inside the project
;;       directory: .env, .env.*, .envrc, *.pem, and *.key.
;;
;; Parameters (injected by wrapper):
;;   _USERS_DIR    - parent directory containing user homes
;;   _HOME         - user home directory
;;   _PROJECT_DIR  - resolved project working directory
;;   _TMPDIR       - macOS per-user temp directory

(version 1)
(deny default)

;; ---------------------------------------------------------------------------
;; Process and system essentials
;; ---------------------------------------------------------------------------
(allow process-exec)
(allow process-fork)
(allow process-info*)
(allow signal)
(allow mach*)
(allow sysctl*)
(allow ipc-posix-shm*)
(allow ipc-posix-sem*)
(allow iokit-open)
(allow system-socket)
(allow system-fsctl)
(allow pseudo-tty)
(allow user-preference-read)
(allow file-ioctl)

;; ---------------------------------------------------------------------------
;; Network - fully allowed
;; ---------------------------------------------------------------------------
(allow network*)

;; ---------------------------------------------------------------------------
;; Read access - global allow, then block users directory except selected paths
;; ---------------------------------------------------------------------------
(allow file-read*)

;; Keep the users directory and $HOME non-listable, while still allowing
;; metadata reads below so runtime path resolution (for example, Node
;; realpath/lstat) can traverse those ancestor directories.
(deny file-read-data (literal (param "_USERS_DIR")))
(deny file-read-data (literal (param "_HOME")))

(deny file-read*
  (require-all
    (subpath (param "_USERS_DIR"))
    (require-not (literal (param "_USERS_DIR")))
    (require-not (literal (param "_HOME")))
    (require-not (subpath (param "_PROJECT_DIR")))
    ;; Allows all ~/src; secrets stored there are readable by the agent.
    (require-not (subpath (string-append (param "_HOME") "/src")))
    ;; Git configuration used by git(1) and related tooling.
    (require-not (literal (string-append (param "_HOME") "/.gitconfig")))
    (require-not (literal (string-append (param "_HOME") "/.gitignore_global")))

    ;; SSH host key verification for git/ssh.
    (require-not (literal (string-append (param "_HOME") "/.ssh/known_hosts")))

    ;; GitHub CLI (`gh(1)`) host/config files. If hosts.yml contains plaintext
    ;; tokens on your machine, remove this exception or use Keychain-backed auth.
    (require-not (literal (string-append (param "_HOME") "/.config/gh/config.yml")))
    (require-not (literal (string-append (param "_HOME") "/.config/gh/hosts.yml")))

    ;; Tool caches/state needed by common CLIs and coding agents.
    (require-not (subpath (string-append (param "_HOME") "/.cache")))
    ;; npm's cache defaults to ~/.npm. This does not allow ~/.npmrc.
    (require-not (subpath (string-append (param "_HOME") "/.npm")))
    (require-not (subpath (string-append (param "_HOME") "/.local")))
    (require-not (subpath (string-append (param "_HOME") "/.pi")))
    (require-not (subpath (string-append (param "_HOME") "/.codex/skills")))
    (require-not (subpath (string-append (param "_HOME") "/.nvm")))
    (require-not (subpath (string-append (param "_HOME") "/Library/Keychains")))
    (require-not (subpath (param "_TMPDIR")))
  ))

;; ---------------------------------------------------------------------------
;; Device files
;; ---------------------------------------------------------------------------
;; Git and other tools commonly open /dev/null read-write.
(allow file-write* (literal "/dev/null"))

;; ---------------------------------------------------------------------------
;; Write access - deny-default, explicit allowlist only
;; ---------------------------------------------------------------------------
(allow file-write* (subpath (param "_PROJECT_DIR")))
(allow file-write* (subpath (string-append (param "_HOME") "/.cache")))
;; npm's cache defaults to ~/.npm. This does not allow ~/.npmrc.
(allow file-write* (subpath (string-append (param "_HOME") "/.npm")))
(allow file-write* (subpath (string-append (param "_HOME") "/.codex/skills")))

;; Pi installs agent skills under ~/.pi/agent/skills.
(allow file-write* (subpath (string-append (param "_HOME") "/.pi/agent/skills")))

;; Pi writes session JSONL files under ~/.pi/agent/sessions. Commands such as
;; /share and /export need the persisted session file to exist.
(allow file-write* (subpath (string-append (param "_HOME") "/.pi/agent/sessions")))

;; Pi writes /debug output directly to this single log file.
(allow file-write* (literal (string-append (param "_HOME") "/.pi/agent/pi-debug.log")))

;; Pi stores OAuth credentials in auth.json. Subscription providers such as
;; OpenAI Codex use short-lived access tokens, so Pi must be able to write this
;; file when it refreshes the token during a long-running session.
(allow file-write* (literal (string-append (param "_HOME") "/.pi/agent/auth.json")))

;; Pi uses proper-lockfile lock directories next to state files. Allow only the
;; lock directories themselves, not general writes to ~/.pi/agent.
(allow file-write* (literal (string-append (param "_HOME") "/.pi/agent/settings.json.lock")))
(allow file-write* (literal (string-append (param "_HOME") "/.pi/agent/auth.json.lock")))

;; Temporary directories. Only allow the configured TMPDIR and /tmp. Keep
;; /private/tmp as the canonical macOS spelling of /tmp.
(allow file-write* (subpath (param "_TMPDIR")))
(allow file-write* (subpath "/tmp"))
(allow file-write* (subpath "/private/tmp"))

;; ---------------------------------------------------------------------------
;; Mandatory write denies - defense-in-depth (HOME)
;; ---------------------------------------------------------------------------
(deny file-write* (subpath (string-append (param "_HOME") "/.ssh")))
(deny file-write* (subpath (string-append (param "_HOME") "/.gnupg")))
(deny file-write* (literal (string-append (param "_HOME") "/.gitconfig")))
(deny file-write* (literal (string-append (param "_HOME") "/.zshrc")))
(deny file-write* (literal (string-append (param "_HOME") "/.bashrc")))
(deny file-write* (literal (string-append (param "_HOME") "/.profile")))
(deny file-write* (literal (string-append (param "_HOME") "/.zprofile")))
(deny file-write* (literal (string-append (param "_HOME") "/.zshenv")))
(deny file-write* (literal (string-append (param "_HOME") "/.zlogout")))
(deny file-write* (literal (string-append (param "_HOME") "/.bash_profile")))
(deny file-write* (literal (string-append (param "_HOME") "/.pgpass")))

;; ---------------------------------------------------------------------------
;; Mandatory write denies - defense-in-depth (PROJECT)
;; ---------------------------------------------------------------------------
(deny file-write* (subpath (string-append (param "_PROJECT_DIR") "/.git/hooks")))
(deny file-write* (literal (string-append (param "_PROJECT_DIR") "/.git/config")))
(deny file-write* (literal (string-append (param "_PROJECT_DIR") "/.bashrc")))
(deny file-write* (literal (string-append (param "_PROJECT_DIR") "/.zshrc")))
(deny file-write* (literal (string-append (param "_PROJECT_DIR") "/.gitconfig")))
(deny file-write* (literal (string-append (param "_PROJECT_DIR") "/.mcp.json")))
(deny file-write*
  (require-all
    (subpath (param "_PROJECT_DIR"))
    (regex #"/\.env(\..*)?$")))
(deny file-write*
  (require-all
    (subpath (param "_PROJECT_DIR"))
    (regex #"/\.envrc$")))
(deny file-write*
  (require-all
    (subpath (param "_PROJECT_DIR"))
    (regex #"\.pem$")))
(deny file-write*
  (require-all
    (subpath (param "_PROJECT_DIR"))
    (regex #"\.key$")))
(deny file-write* (subpath (string-append (param "_PROJECT_DIR") "/.vscode")))
(deny file-write* (subpath (string-append (param "_PROJECT_DIR") "/.zed")))
(deny file-write* (subpath (string-append (param "_PROJECT_DIR") "/.idea")))
