#!/usr/bin/env bash
# sb - Run (basically) any command inside a macOS sandbox-exec jail.
#
# Usage: sb [options] <command> [args...]
#
# Options:
#   --allow-env=NAME   Pass through one additional environment variable
#   --allow-env NAME   Same
#   --profile=PATH     Use an explicit sandbox profile path
#   --profile PATH     Same
#
# Examples:
#   sb npm install                         # sandbox with a sanitized environment
#   sb --allow-env=ATLASSIAN_API_TOKEN pi  # pass through one additional variable
#   sb --profile ./default-profile.sb pi   # use a profile from the project
#
# Policy (defined in default-profile.sb):
#   - Writes are blocked outside the project directory, ~/.cache/, ~/.codex/skills/, and temp directories.
#   - Reads of private keys, auth tokens, etc., are blocked.
#   - Network, execution, and IPC are all allowed.
#
# Safety: refuses to run from $HOME (which would grant write access to the entire home directory).

set -euo pipefail

ALLOWED_ENV=()
PROFILE=""

# Parse sb-specific flags before the command.
while [[ $# -gt 0 ]]; do
    case "$1" in
        --allow-env=*) ALLOWED_ENV+=("${1#*=}"); shift ;;
        --allow-env)
            if [[ $# -lt 2 ]]; then
                echo "error: --allow-env requires an environment variable name" >&2
                exit 1
            fi
            ALLOWED_ENV+=("$2")
            shift 2 ;;
        --profile=*) PROFILE="${1#*=}"; shift ;;
        --profile)
            if [[ $# -lt 2 ]]; then
                echo "error: --profile requires a sandbox profile path" >&2
                exit 1
            fi
            PROFILE="$2"
            shift 2 ;;
        --) shift; break ;;
        -h|--help)
            echo "Usage: sb [options] <command> [args...]"
            echo "Options:"
            echo "  --allow-env=NAME   Pass through one additional environment variable"
            echo "  --allow-env NAME   Same"
            echo "  --profile=PATH     Use an explicit sandbox profile path"
            echo "  --profile PATH     Same"
            exit 0 ;;
        -*) echo "error: unknown option: $1" >&2; exit 1 ;;
        *)  break ;;
    esac
done

# Find the profile in the home directory unless an explicit one was provided.
if [[ -z "$PROFILE" ]]; then
    PROFILE="${HOME}/.config/sb/default-profile.sb"
fi

if [[ ! -f "$PROFILE" ]]; then
    echo "error: sandbox profile not found: ${PROFILE}" >&2
    exit 1
fi

if [[ $# -eq 0 ]]; then
    echo "Usage: sb [options] <command> [args...]" >&2
    echo "Example: sb bash" >&2
    echo "Example: sb --allow-env=ATLASSIAN_API_TOKEN pi" >&2
    exit 1
fi

# Resolve real paths.
RESOLVED_HOME="$(cd "$HOME" && pwd -P)"
PROJECT_DIR="$(pwd -P)"

# Walk up to the Git root if inside a repository (so the full project is writable).
GIT_ROOT="$(git -C "$PROJECT_DIR" rev-parse --show-toplevel 2>/dev/null || true)"
if [[ -n "$GIT_ROOT" ]]; then
    PROJECT_DIR="$(cd "$GIT_ROOT" && pwd -P)"
fi

# Safety guard: refuse to run from $HOME directly.
if [[ "$PROJECT_DIR" == "$RESOLVED_HOME" ]]; then
    echo "error: refusing to run from \$HOME ($RESOLVED_HOME)" >&2
    echo "" >&2
    echo "Running from \$HOME would grant write access to your entire" >&2
    echo "home directory, defeating the purpose of the sandbox." >&2
    echo "" >&2
    echo "Instead, cd into a project directory first:" >&2
    echo "  cd ~/my-project && sb <command>" >&2
    exit 1
fi

# Resolve TMPDIR (macOS sets this to a per-user path like /var/folders/xx/...).
RESOLVED_TMPDIR="$(cd "${TMPDIR:-/tmp}" && pwd -P)"

SANDBOX_ARGS=(
    sandbox-exec -f "$PROFILE"
    -D "_HOME=${RESOLVED_HOME}"
    -D "_PROJECT_DIR=${PROJECT_DIR}"
    -D "_TMPDIR=${RESOLVED_TMPDIR}"
)

# Build a sanitized environment: only essentials, no secrets.
ENV_ARGS=(
    /usr/bin/env -i
    "HOME=${RESOLVED_HOME}"
    "USER=${USER:-}"
    "SHELL=${SHELL:-/bin/zsh}"
    "TERM=${TERM:-xterm-256color}"
    "LANG=${LANG:-en_US.UTF-8}"
    "PATH=${PATH}"
    "TMPDIR=${RESOLVED_TMPDIR}"
)
# Pass through the SSH agent socket (for Git over SSH; the socket, not keys).
[[ -n "${SSH_AUTH_SOCK:-}" ]] && ENV_ARGS+=("SSH_AUTH_SOCK=${SSH_AUTH_SOCK}")
# Pass through editor preferences.
[[ -n "${EDITOR:-}" ]] && ENV_ARGS+=("EDITOR=${EDITOR}")
[[ -n "${VISUAL:-}" ]] && ENV_ARGS+=("VISUAL=${VISUAL}")
# Pass through XDG directories (tools rely on these).
[[ -n "${XDG_CONFIG_HOME:-}" ]] && ENV_ARGS+=("XDG_CONFIG_HOME=${XDG_CONFIG_HOME}")
[[ -n "${XDG_DATA_HOME:-}" ]] && ENV_ARGS+=("XDG_DATA_HOME=${XDG_DATA_HOME}")
[[ -n "${XDG_CACHE_HOME:-}" ]] && ENV_ARGS+=("XDG_CACHE_HOME=${XDG_CACHE_HOME}")
[[ -n "${XDG_RUNTIME_DIR:-}" ]] && ENV_ARGS+=("XDG_RUNTIME_DIR=${XDG_RUNTIME_DIR}")

for env_name in "${ALLOWED_ENV[@]}"; do
    if [[ ! "$env_name" =~ ^[A-Za-z_][A-Za-z0-9_]*$ ]]; then
        echo "error: invalid environment variable name for --allow-env: $env_name" >&2
        exit 1
    fi
    if [[ -z "${!env_name+x}" ]]; then
        echo "error: environment variable requested by --allow-env is not set: $env_name" >&2
        exit 1
    fi
    ENV_ARGS+=("${env_name}=${!env_name}")
done

exec "${SANDBOX_ARGS[@]}" "${ENV_ARGS[@]}" "$@"
