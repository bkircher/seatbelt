; tools/git.sb

; Git configuration used by git(1) and related tooling
(allow file-read*
    (literal (string-append home-dir "/.gitconfig"))
    (literal (string-append home-dir "/.gitignore_global"))
    (literal (string-append home-dir "/.config/git/config"))
    (literal (string-append home-dir "/.config/git/ignore")))
